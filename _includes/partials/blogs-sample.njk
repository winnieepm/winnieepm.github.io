<section class="view-all-items">
    <div class="collection-container">
    {% assign blogsToShow = collections.blogs | reverse | limit: 4 %}
    {%- for post in blogsToShow -%}
        <div class="blog thumbnail">
            <div class="thumbnail-header">
                <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
                <span>{{ post.data.dateString }}</span>
                <p>{{ post.data.logline }}</p>
            </div>
            <a class="view-all-btn" href="{{ post.url }}"><< Read full blog >></a>
        </div>
    {%- endfor -%}
        <a class="view-all-link" href="/blogs/">View all blogs...</a>
    </div>
</section>